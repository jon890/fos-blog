# ============================================================
# GitHub Integration
# ============================================================

# GitHub Personal Access Token (optional, but recommended for higher rate limits)
# Create one at: https://github.com/settings/tokens
# Required scopes: public_repo (for public repositories)
GITHUB_TOKEN=your_github_token_here

# GitHub repository to sync content from
GITHUB_OWNER=jon890
GITHUB_REPO=fos-study

# Branch to sync from (default: main)
# GITHUB_BRANCH=main

# ============================================================
# Database
# ============================================================

# MySQL connection string (Docker Compose: local/docker-compose.yml, port 13307)
DATABASE_URL=mysql://fos_user:fos_password@localhost:13307/fos_blog

# Set to "false" to disable MySQL FULLTEXT search and fall back to LIKE queries
# USE_FULLTEXT_SEARCH=true

# ============================================================
# API Security
# ============================================================

# Protects POST /api/sync endpoint — required in production
SYNC_API_KEY=your_random_api_key_here

# ============================================================
# Logging
# ============================================================

# pino log level: trace | debug | info | warn | error | fatal (default: info)
# LOG_LEVEL=info

# ============================================================
# Public / SEO
# ============================================================

# Canonical URL for sitemap and OG tags
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google Search Console verification code
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_code_here

# Google AdSense Publisher ID
NEXT_PUBLIC_GOOGLE_ADSENSE_ID=ca-pub-XXXXXXXXXXXXXXXX
